// — Statistics —

function mean(a){if(!a.length)return 0;for(var s=0,i=0;i<a.length;i++)s+=a[i];return s/a.length}
function std(a){if(a.length<2)return 0;var m=mean(a),s=0;for(var i=0;i<a.length;i++)s+=(a[i]-m)*(a[i]-m);return Math.sqrt(s/(a.length-1))}
