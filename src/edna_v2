  if(this._ta.length>=6){var c7=cv(this._ta);r.contactArea=c7>.06?Math.min(1,.6+c7*.8):.15}
  if(this._td.length>=6){var c8=cv(this._td);r.clickDuration=c8>.3?Math.min(1,.6+c8*.3):c8<.08?.15:.45}
