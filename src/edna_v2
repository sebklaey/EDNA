var SK=["timingDistribution","timingEntropy","autocorrelation","naturalDrift",
  "pathCurvature","speedVariation","scrollBehavior","deviceMotion","contactArea",
  "clickDuration","readingPauses","interactionMap","motionCharacter","corrections",
  "typingBursts","eventRate"];

var BASE=[{n:2,m:3,a:.3,p:0},{n:3,m:5,a:.2,p:.5},{n:1,m:4,a:.25,p:1}];

function harmonics(sig){var h=[],i;for(i=0;i<SK.length;i++)h.push(typeof sig[SK[i]]==="number"?sig[SK[i]]:0);return h}
function modes(h){var m=[],i,j;for(i=0;i<h.length;i++)for(j=i+1;j<h.length;j++){var a=(h[i]+h[j])/2;
  if(a>.1)m.push({n:1+h[i]*4.5,m:1+h[j]*4.5,a:a,p:(h[i]-h[j])*Math.PI})}
  m.sort(function(a,b){return b.a-a.a});return m.slice(0,12)}
function chladni(M,x,y){var s=0,i;for(i=0;i<M.length;i++){var m=M[i];
  s+=(Math.cos(m.n*x+m.p)*Math.cos(m.m*y)-Math.cos(m.m*x)*Math.cos(m.n*y+m.p))*m.a}return s}
