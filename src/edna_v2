  var H=0;for(i=0;i<c.length;i++)if(c[i]>0){var p=c[i]/s.length;H-=p*Math.log(p)/Math.LN2}
  return H/(Math.log(bins)/Math.LN2);
}
function acorr(a){
  if(a.length<8)return 0;var m=mean(a),n=0,d=0,i;
  for(i=0;i<a.length-1;i++){n+=(a[i]-m)*(a[i+1]-m);d+=(a[i]-m)*(a[i]-m)}
  d+=(a[a.length-1]-m)*(a[a.length-1]-m);return d?n/d:0;
