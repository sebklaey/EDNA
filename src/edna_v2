  if(this._ma.length>=10){var df=[],k;for(k=1;k<this._ma.length;k++)df.push(Math.abs(this._ma[k]-this._ma[k-1]));
    var c2=cv(df);r.pathCurvature=c2>.2&&c2<3.5?Math.min(1,.55+c2*.22):c2<.06?.1:.3}
