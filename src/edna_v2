    r.speedVariation=Math.max(.05,Math.min(1,s2))}
  if(this._si.length>=5){var c4=cv(this._si),c5=cv(this._sv),s3=.5;
    if(c4>.2)s3+=.2;if(c5>.2)s3+=.2;if(this._sdc>0)s3+=.1;if(c4<.06)s3-=.35;
