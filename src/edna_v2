// — Confidence —

var W={timingDistribution:2.5,timingEntropy:1.5,autocorrelation:2,naturalDrift:1.5,
  pathCurvature:2,speedVariation:2,scrollBehavior:2.5,deviceMotion:3,contactArea:2,
  clickDuration:2,readingPauses:2.5,interactionMap:2,motionCharacter:2,corrections:1.5,
