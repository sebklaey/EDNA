    if(p.length>=8){var rc=cv(p),lp=[],j;for(j=0;j<p.length;j++)lp.push(Math.log(p[j]));var lc=cv(lp);
      r.timingDistribution=rc>.25&&lc<rc*.9?Math.min(1,.65+rc*.35):rc<.06?.1:Math.min(1,.45+rc*.3)}
    var e=entropy(iv);r.timingEntropy=e>=.6?Math.min(1,.6+e*.4):e>=.4?.5+(e-.4)*1.5:e<.3?.15:.4;
    var ac=acorr(iv);r.autocorrelation=ac>.02&&ac<.7?.6+ac*.55:Math.abs(ac)<.01?.35:.4;
    if(iv.length>=20){var rc2=iv.slice(-200),t=Math.floor(rc2.length/3),o=mean(rc2);
      if(o){var d=Math.abs(mean(rc2.slice(0,t))-mean(rc2.slice(-t)))/o;
